<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="OverlayEngine.App.MainWindow"
    Width="1200"
    Height="700">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel
            Orientation="Horizontal"
            Margin="10"
            Spacing="10">

            <Button
                Content="Lock Overlay"
                Click="LockOverlay_Click"/>

        </StackPanel>

        <Canvas
            x:Name="WidgetsCanvas"
            Grid.Row="1"/>

    </Grid>

</Window>